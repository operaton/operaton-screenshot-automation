<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_Invoice"
                  targetNamespace="http://operaton.org/examples/invoice"
                  exporter="Operaton Modeler"
                  exporterVersion="1.0.0">
  
  <bpmn:process id="invoice" name="Invoice Receipt" isExecutable="true" camunda:historyTimeToLive="30">
    
    <bpmn:startEvent id="StartEvent_InvoiceReceived" name="Invoice&#10;received">
      <bpmn:outgoing>Flow_ToApproveInvoice</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:sequenceFlow id="Flow_ToApproveInvoice" sourceRef="StartEvent_InvoiceReceived" targetRef="Task_ApproveInvoice" />
    
    <bpmn:userTask id="Task_ApproveInvoice" name="Approve Invoice" camunda:assignee="${approver}" camunda:candidateGroups="accounting">
      <bpmn:incoming>Flow_ToApproveInvoice</bpmn:incoming>
      <bpmn:incoming>Flow_ReviewToApprove</bpmn:incoming>
      <bpmn:outgoing>Flow_ToGatewayApproved</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:sequenceFlow id="Flow_ToGatewayApproved" sourceRef="Task_ApproveInvoice" targetRef="Gateway_InvoiceApproved" />
    
    <bpmn:exclusiveGateway id="Gateway_InvoiceApproved" name="Invoice&#10;approved?">
      <bpmn:incoming>Flow_ToGatewayApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotApproved</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:sequenceFlow id="Flow_Approved" name="yes" sourceRef="Gateway_InvoiceApproved" targetRef="Task_PrepareBankTransfer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:sequenceFlow id="Flow_NotApproved" name="no" sourceRef="Gateway_InvoiceApproved" targetRef="Task_ReviewInvoice">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!approved}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:userTask id="Task_ReviewInvoice" name="Review Invoice" camunda:assignee="demo" camunda:candidateGroups="accounting">
      <bpmn:incoming>Flow_NotApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_ToGatewayClarified</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:sequenceFlow id="Flow_ToGatewayClarified" sourceRef="Task_ReviewInvoice" targetRef="Gateway_ReviewClarified" />
    
    <bpmn:exclusiveGateway id="Gateway_ReviewClarified" name="Review&#10;clarified?">
      <bpmn:incoming>Flow_ToGatewayClarified</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewToApprove</bpmn:outgoing>
      <bpmn:outgoing>Flow_ReviewToEnd</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:sequenceFlow id="Flow_ReviewToApprove" name="yes" sourceRef="Gateway_ReviewClarified" targetRef="Task_ApproveInvoice">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${clarified}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:sequenceFlow id="Flow_ReviewToEnd" name="no" sourceRef="Gateway_ReviewClarified" targetRef="EndEvent_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!clarified}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:userTask id="Task_PrepareBankTransfer" name="Prepare Bank Transfer" camunda:candidateGroups="accounting">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_PrepareBankTransfer" targetRef="EndEvent_Paid" />
    
    <bpmn:endEvent id="EndEvent_Paid" name="Invoice&#10;paid">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:endEvent id="EndEvent_Rejected" name="Invoice&#10;rejected">
      <bpmn:incoming>Flow_ReviewToEnd</bpmn:incoming>
    </bpmn:endEvent>
    
  </bpmn:process>
  
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="invoice">
      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent_InvoiceReceived">
        <dc:Bounds x="180" y="200" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="175" y="243" width="46" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApproveInvoice_di" bpmnElement="Task_ApproveInvoice">
        <dc:Bounds x="270" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InvoiceApproved_di" bpmnElement="Gateway_InvoiceApproved" isMarkerVisible="true">
        <dc:Bounds x="425" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="425" y="156" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewInvoice_di" bpmnElement="Task_ReviewInvoice">
        <dc:Bounds x="400" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ReviewClarified_di" bpmnElement="Gateway_ReviewClarified" isMarkerVisible="true">
        <dc:Bounds x="295" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="295" y="382" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareBankTransfer_di" bpmnElement="Task_PrepareBankTransfer">
        <dc:Bounds x="530" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Paid_di" bpmnElement="EndEvent_Paid">
        <dc:Bounds x="692" y="200" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="690" y="243" width="40" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="182" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="177" y="375" width="46" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_ToApproveInvoice_di" bpmnElement="Flow_ToApproveInvoice">
        <di:waypoint x="216" y="218" />
        <di:waypoint x="270" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToGatewayApproved_di" bpmnElement="Flow_ToGatewayApproved">
        <di:waypoint x="370" y="218" />
        <di:waypoint x="425" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approved_di" bpmnElement="Flow_Approved">
        <di:waypoint x="475" y="218" />
        <di:waypoint x="530" y="218" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="494" y="200" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotApproved_di" bpmnElement="Flow_NotApproved">
        <di:waypoint x="450" y="243" />
        <di:waypoint x="450" y="310" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="459" y="273" width="13" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToGatewayClarified_di" bpmnElement="Flow_ToGatewayClarified">
        <di:waypoint x="400" y="350" />
        <di:waypoint x="345" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReviewToApprove_di" bpmnElement="Flow_ReviewToApprove">
        <di:waypoint x="320" y="325" />
        <di:waypoint x="320" y="258" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="327" y="288" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReviewToEnd_di" bpmnElement="Flow_ReviewToEnd">
        <di:waypoint x="295" y="350" />
        <di:waypoint x="218" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="250" y="332" width="13" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEnd_di" bpmnElement="Flow_ToEnd">
        <di:waypoint x="630" y="218" />
        <di:waypoint x="692" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>