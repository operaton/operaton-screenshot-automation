{
  "version": "1.0.0",
  "description": "Minimal screenshot definitions for testing",

  "defaults": {
    "viewport": { "width": 1920, "height": 1080 },
    "deviceScaleFactor": 2,
    "waitForSelector": ".content-wrapper",
    "waitTimeout": 10000
  },

  "categories": {
    "cockpit": {
      "description": "Cockpit webapp screenshots",
      "baseUrl": "/operaton/app/cockpit/default"
    },
    "tasklist": {
      "description": "Tasklist webapp screenshots",
      "baseUrl": "/operaton/app/tasklist/default"
    },
    "admin": {
      "description": "Admin webapp screenshots",
      "baseUrl": "/operaton/app/admin/default"
    }
  },

  "screenshots": [
    {
      "id": "cockpit-dashboard",
      "category": "cockpit",
      "description": "Cockpit main dashboard",
      "path": "#/dashboard",
      "outputFile": "cockpit/dashboard.png",
      "waitForSelector": ".dashboard"
    },
    {
      "id": "cockpit-processes",
      "category": "cockpit",
      "description": "Process definitions list",
      "path": "#/processes",
      "outputFile": "cockpit/processes.png"
    },
    {
      "id": "cockpit-decisions",
      "category": "cockpit",
      "description": "Decision definitions list",
      "path": "#/decisions",
      "outputFile": "cockpit/decisions.png"
    },
    {
      "id": "tasklist-dashboard",
      "category": "tasklist",
      "description": "Tasklist main view",
      "path": "#/",
      "outputFile": "tasklist/dashboard.png"
    },
    {
      "id": "admin-users",
      "category": "admin",
      "description": "User management",
      "path": "#/users",
      "outputFile": "admin/users.png"
    }
  ],

  "users": [
    {
      "id": "demo",
      "firstName": "Demo",
      "lastName": "Demo",
      "email": "demo@operaton.org",
      "password": "demo"
    },
    {
      "id": "john",
      "firstName": "John",
      "lastName": "Doe",
      "email": "john@operaton.org",
      "password": "john"
    },
    {
      "id": "mary",
      "firstName": "Mary",
      "lastName": "Smith",
      "email": "mary@operaton.org",
      "password": "mary"
    },
    {
      "id": "peter",
      "firstName": "Peter",
      "lastName": "Parker",
      "email": "peter@operaton.org",
      "password": "peter"
    }
  ],

  "groups": [
    { "id": "operaton-admin", "name": "Operaton Admin", "type": "SYSTEM" },
    { "id": "accounting", "name": "Accounting", "type": "WORKFLOW" },
    { "id": "management", "name": "Management", "type": "WORKFLOW" },
    { "id": "sales", "name": "Sales", "type": "WORKFLOW" }
  ]
}
