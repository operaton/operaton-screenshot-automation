# =============================================================================
# Operaton Screenshot Automation - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Operaton Instance Configuration
# -----------------------------------------------------------------------------
OPERATON_BASE_URL=https://operaton-doc.open-regels.nl
OPERATON_REST_URL=https://operaton-doc.open-regels.nl/engine-rest

# Authentication
OPERATON_USERNAME=demo
OPERATON_PASSWORD=demo

# -----------------------------------------------------------------------------
# Screenshot Capture Configuration
# -----------------------------------------------------------------------------
# Viewport dimensions - adjust to match existing documentation screenshots
# Original Camunda docs used approximately 1200x800
SCREENSHOT_WIDTH=1200
SCREENSHOT_HEIGHT=800

# Device scale factor (1 = standard, 2 = retina/high-DPI)
# Use 1 to match original screenshot sizes
SCREENSHOT_SCALE=1

# Browser mode (true = headless, false = visible browser window)
HEADLESS=true

# Path to screenshots.json config file
CONFIG_PATH=./config/screenshots.json

# Output directory for captured screenshots
OUTPUT_DIR=./output/screenshots

# -----------------------------------------------------------------------------
# Documentation Paths
# -----------------------------------------------------------------------------
# Path to the Operaton documentation repository 'docs' folder
# Used by: scan-docs.js, replace-screenshots.js
# Example Windows: C:/Users/username/Development/documentation/docs
# Example Linux/Mac: /home/username/projects/documentation/docs
DOCS_PATH=

# Path to the documentation 'docs/assets' folder (for Docusaurus versioning)
# Images in docs/assets are included in version snapshots
# Used by: replace-screenshots.js
# Example Windows: C:/Users/username/Development/documentation/docs/assets
# Example Linux/Mac: /home/username/projects/documentation/docs/assets
ASSETS_PATH=

# Legacy: Path to 'static/img' folder (optional, for backwards compatibility)
# Only set this if you still have images in static/img
# STATIC_PATH=

# Directory where generated screenshot configs are saved
# Used by: scan-docs.js
SCAN_OUTPUT_DIR=./output/scan

# -----------------------------------------------------------------------------
# Screenshot Replacement Configuration
# -----------------------------------------------------------------------------
# Dry run mode - when true, shows what would be replaced without copying files
# Set to false to actually replace screenshots in documentation
DRY_RUN=true

# Verbose output for replacement operations
VERBOSE=false

# -----------------------------------------------------------------------------
# Debug Mode
# -----------------------------------------------------------------------------
# Enable debug output for all scripts
DEBUG=false

# -----------------------------------------------------------------------------
# Webapp URLs (derived from OPERATON_BASE_URL)
# These are typically not needed to be changed
# -----------------------------------------------------------------------------
COCKPIT_URL=${OPERATON_BASE_URL}/operaton/app/cockpit/default
TASKLIST_URL=${OPERATON_BASE_URL}/operaton/app/tasklist/default
ADMIN_URL=${OPERATON_BASE_URL}/operaton/app/admin/default
WELCOME_URL=${OPERATON_BASE_URL}/operaton/app/welcome/default
