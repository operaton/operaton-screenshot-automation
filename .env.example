# Operaton Instance Configuration
OPERATON_BASE_URL=https://operaton-doc.open-regels.nl
OPERATON_REST_URL=https://operaton-doc.open-regels.nl/engine-rest

# Authentication (if required)
OPERATON_USERNAME=demo
OPERATON_PASSWORD=demo

# Screenshot Configuration
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080
SCREENSHOT_SCALE=2

# Webapp URLs
COCKPIT_URL=${OPERATON_BASE_URL}/operaton/app/cockpit/default
TASKLIST_URL=${OPERATON_BASE_URL}/operaton/app/tasklist/default
ADMIN_URL=${OPERATON_BASE_URL}/operaton/app/admin/default
WELCOME_URL=${OPERATON_BASE_URL}/operaton/app/welcome/default

# Output Configuration
OUTPUT_DIR=./output/screenshots

# Documentation Analysis
# Path to markdown files directory (e.g., Docusaurus docs folder)
# Example for Operaton docs: ../documentation/docs
DOCS_PATH=../../docs
# Set to true to flag ALL images for replacement (ignore pattern detection)
REPLACE_ALL=false

# Process Deployment
# Directory containing BPMN/DMN/CMMN files to deploy
# PROCESSES_DIR=./processes
# Source identifier shown in Cockpit deployments list
DEPLOYMENT_SOURCE=screenshot-automation

# Debug Mode
DEBUG=false
HEADLESS=true